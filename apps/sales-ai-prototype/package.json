{
  "name": "payments-agents-team",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "node scripts/free-port.mjs 3000 && node scripts/clean-next.mjs && next dev -p 3000",
    "dev:fast": "npm run dev",
    "dev:skip-clean": "node scripts/free-port.mjs 3000 && node ./node_modules/next/dist/bin/next dev -p 3000",
    "dev:fresh": "npm run dev",
    "dev:clean": "bash scripts/dev-clean.sh",
    "doctor:dev-styles": "node scripts/doctor-dev-styles.mjs",
    "dev:turbo": "node scripts/free-port.mjs 3000 && node scripts/clean-next.mjs && next dev --turbopack -p 3000",
    "dev:3000": "next dev -p 3000",
    "build": "next build",
    "rebuild": "npm run clean && npm run build",
    "start": "next start",
    "start:3000": "next start -p 3000",
    "lint": "eslint",
    "update-sheet": "bun run scripts/update-google-sheet.ts",
    "confluence:create-areti-summary": "bun run scripts/confluence/create-payments-agents-suite-summary-for-areti.ts",
    "confluence:bootstrap-hub": "bun run scripts/confluence/bootstrap-agent-hub.ts",
    "confluence:read-page": "bun run scripts/confluence/read-page.ts",
    "confluence:preview-hub-root": "bun run scripts/confluence/preview-hub-root.ts",
    "confluence:rename-hub-pages": "bun run scripts/confluence/rename-hub-pages.ts",
    "confluence:rename-hub-child-pages": "bun run scripts/confluence/rename-hub-child-pages.ts",
    "confluence:delete-squad-pages": "bun run scripts/confluence/delete-squad-pages.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.31.3",
    "@headlessui/react": "^2.2.9",
    "clsx": "^2.1.1",
    "google-auth-library": "^9.14.1",
    "googleapis": "^140.0.1",
    "highcharts": "^12.5.0",
    "highcharts-react-official": "^3.2.3",
    "lucide-react": "^0.575.0",
    "next": "15.5.9",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-grid-layout": "^2.2.2",
    "react-hotkeys-hook": "^5.2.4",
    "react-responsive": "^10.0.1",
    "react-tooltip": "^5.30.0",
    "react-youtube": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.8"
}
