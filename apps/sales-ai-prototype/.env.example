# Copy to `.env.local` for local use. Do not commit real secrets.

CONFLUENCE_USERNAME=your.name@xero.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_URL=https://xero.atlassian.net/wiki

# Production: hub under XFS → Payments Agents Team. Use a test space key for local experiments.
CONFLUENCE_SPACE_KEY=XFS

# Optional: change where the hub tree is created.
CONFLUENCE_AGENT_HUB_PREFIX=Payments Agents Hub

# Production: hub root is created under this page (XFS → Payments Agents Team).
CONFLUENCE_AGENT_HUB_PARENT_PAGE_ID=271928754915

# Optional: load Figma MCP html-to-design capture.js (third-party; can fail when blocked/offline).
# Leave unset for stable local dev. Enable when you use that workflow:
# NEXT_PUBLIC_ENABLE_FIGMA_MCP_CAPTURE=true
