{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "text": {
      "default":  { "$type": "color", "$value": "#333333" },
      "muted":    { "$type": "color", "$value": "#666666" },
      "faint":    { "$type": "color", "$value": "#999999" },
      "inverse":  { "$type": "color", "$value": "#FFFFFF" }
    },
    "action": {
      "default":  { "$type": "color", "$value": "#0078C8" },
      "hover":    { "$type": "color", "$value": "#005999" },
      "active":   { "$type": "color", "$value": "#004477" },
      "focus":    { "$type": "color", "$value": "#0078C8" }
    },
    "theme": {
      "ab":       { "$type": "color", "$value": "#FFFFFF" },
      "sb":       { "$type": "color", "$value": "#F4F5F7" }
    },
    "border": {
      "subtle":   { "$type": "color", "$value": "#ECEEF1" },
      "soft":     { "$type": "color", "$value": "#D4D7DC" },
      "regular":  { "$type": "color", "$value": "#B3B7BD" },
      "strong":   { "$type": "color", "$value": "#8C9196" }
    },
    "xero": {
      "logo":     { "$type": "color", "$value": "#13B5EA" }
    },
    "indicator": {
      "red":       { "$type": "color", "$value": "#D13B3B" },
      "green":     { "$type": "color", "$value": "#1D8C3E" },
      "yellow":    { "$type": "color", "$value": "#B8860B" },
      "orange":    { "$type": "color", "$value": "#D67019" },
      "blue":      { "$type": "color", "$value": "#0078C8" },
      "violet":    { "$type": "color", "$value": "#6B47DC" },
      "grape":     { "$type": "color", "$value": "#9B2FAE" },
      "pink":      { "$type": "color", "$value": "#C44A8A" },
      "mint":      { "$type": "color", "$value": "#0FA382" },
      "turquoise": { "$type": "color", "$value": "#0D8A8A" },
      "grey":      { "$type": "color", "$value": "#666666" }
    }
  },
  "font": {
    "base": { "$type": "fontFamily", "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Oxygen-Sans", "Ubuntu", "Cantarell", "Helvetica Neue", "sans-serif"] }
  },
  "spacing": {
    "0":  { "$type": "dimension", "$value": "0px" },
    "2":  { "$type": "dimension", "$value": "2px" },
    "4":  { "$type": "dimension", "$value": "4px" },
    "8":  { "$type": "dimension", "$value": "8px" },
    "12": { "$type": "dimension", "$value": "12px" },
    "16": { "$type": "dimension", "$value": "16px" },
    "20": { "$type": "dimension", "$value": "20px" },
    "24": { "$type": "dimension", "$value": "24px" },
    "32": { "$type": "dimension", "$value": "32px" },
    "48": { "$type": "dimension", "$value": "48px" },
    "64": { "$type": "dimension", "$value": "64px" }
  },
  "typography": {
    "fontSize": {
      "10": { "$type": "dimension", "$value": "10px" },
      "11": { "$type": "dimension", "$value": "11px" },
      "12": { "$type": "dimension", "$value": "12px" },
      "13": { "$type": "dimension", "$value": "13px" },
      "14": { "$type": "dimension", "$value": "14px" },
      "15": { "$type": "dimension", "$value": "15px" },
      "17": { "$type": "dimension", "$value": "17px" },
      "22": { "$type": "dimension", "$value": "22px" },
      "24": { "$type": "dimension", "$value": "24px" },
      "28": { "$type": "dimension", "$value": "28px" },
      "32": { "$type": "dimension", "$value": "32px" },
      "44": { "$type": "dimension", "$value": "44px" },
      "64": { "$type": "dimension", "$value": "64px" }
    }
  },
  "borderRadius": {
    "none":   { "$type": "dimension", "$value": "0px" },
    "small":  { "$type": "dimension", "$value": "2px" },
    "medium": { "$type": "dimension", "$value": "4px" },
    "large":  { "$type": "dimension", "$value": "8px" },
    "xlarge": { "$type": "dimension", "$value": "12px" },
    "max":    { "$type": "dimension", "$value": "9999px" },
    "circle": { "$type": "dimension", "$value": "50%" }
  },
  "icon": {
    "small":  { "$type": "dimension", "$value": "16px" },
    "large":  { "$type": "dimension", "$value": "24px" },
    "xlarge": { "$type": "dimension", "$value": "32px" }
  }
}
