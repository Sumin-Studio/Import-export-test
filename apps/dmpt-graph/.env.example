# Jira (server-side). When incomplete, the app serves fixture graph/issue data.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_DMPT_PROJECT=DMPT
# Optional: comma-separated status names for /api/graph (must match Jira). Defaults to DMPT dependency workflow list.
# JIRA_GRAPH_STATUSES=Escalation process,Assess dependency,Raise Dependency,Deliver work,Ready for Delivery
# Optional: full JQL override (replaces the default project + status in (...)).
# JIRA_GRAPH_JQL=project = DMPT AND status in ("Escalation process") ORDER BY created DESC
# Set to 1 or call /api/graph?debug=1 to include the resolved `jql` in the JSON (paste into Jira search).
# JIRA_GRAPH_DEBUG=1
# Set to 1 to skip the extra project probe when the graph JQL returns no rows.
# JIRA_GRAPH_SKIP_PROBE=1
MAX_GRAPH_ISSUES=80

# Portkey (server-side, `portkey-ai` SDK). Omit PORTKEY_API_KEY to skip AI summaries.
# The client sends the same header as curl: `x-portkey-api-key: <PORTKEY_API_KEY>`.
PORTKEY_API_KEY=
# Gateway base URL including `/v1` (the SDK appends `/chat/completions`). Omit to use Portkey cloud default.
# For an internal gateway (same contract as Portkey curl), set e.g.:
# PORTKEY_BASE_URL=https://llm-gateway.xgw.xero-test.com/v1
# Gateway model alias (must exist on that gateway), e.g. @bedrock/global.anthropic.claude-sonnet-4-6
PORTKEY_MODEL=@vertexai-preview/gemini-3.1-flash-lite-preview
# Optional: only set these if your gateway requires an explicit virtual key or saved config.
# PORTKEY_VIRTUAL_KEY=
# PORTKEY_CONFIG=

# Browser "Open in Jira" links (same host as JIRA_BASE_URL is typical).
NEXT_PUBLIC_JIRA_BASE_URL=https://your-domain.atlassian.net
