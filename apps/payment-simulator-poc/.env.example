# Vercel / CI: add NPM_TOKEN (Artifactory npm token for @xero/* packages) in the Vercel project
# Environment Variables — required for `npm ci` on the build machine. Without it, the install fails with 401.

# Marketing shell on `/`: fake-xero-com (default) | none — see `src/entry-points/ActiveMarketingEntry.tsx`
# NEXT_PUBLIC_MARKETING_ENTRY=none

# Without NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY the app uses the XUI mock tile (no Stripe.js).
# To force the mock even when keys are set: NEXT_PUBLIC_USE_MOCK_TILE=true

# Stripe test mode (https://dashboard.stripe.com/test/apikeys)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Default: Pay never charges (demo only). Set to false to enable real test payments.
# NEXT_PUBLIC_STRIPE_PAY_DEMO_ONLY=false

# Optional: When the marketing shell is opened on a different origin than this app
# (e.g. a campaign URL), set the payment-simulator base. If unset, links use same-origin paths.
# If set, include the port you use in the browser (e.g. :3002); mismatched ports break CTAs.
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:3002

# Optional: Stripe Connect — same connected account for API + Elements (mybills pattern).
# Server creates the PaymentIntent on this account; the browser loads Stripe.js for it.
# Prefer server-only (not sent to the client bundle):
# STRIPE_CONNECTED_ACCOUNT_ID=acct_...
# Or use the public name (must match the account used on the server):
# NEXT_PUBLIC_STRIPE_CONNECTED_ACCOUNT_ID=acct_...
